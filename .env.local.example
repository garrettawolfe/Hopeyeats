# Gmail credentials for sending emails
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate an App Password: Google Account > Security > 2-Step Verification > App Passwords
# 3. Select "Mail" and "Other (Custom name)" — copy the 16-character password below

GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Upstash Redis — for persistent storage of scheduled snipes
# Create a database at https://console.upstash.com/redis
# Copy REST URL and REST Token from the database dashboard

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Upstash QStash — for scheduling snipes to fire at drop time
# From https://console.upstash.com/qstash — copy token and signing keys

QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_xxx
QSTASH_NEXT_SIGNING_KEY=sig_xxx

# The stable production URL used when QStash fires a scheduled snipe callback
# Must match your Vercel deployment domain (not the preview URL)

NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
